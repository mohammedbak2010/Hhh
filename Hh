-- ===== وظائف السرقة =====
local function IsOwnPrompt(p)
    return Char ~= nil and p:IsDescendantOf(Char)
end

local function GetPromptPos(prompt)
    local pos
    pcall(function()
        local par = prompt.Parent
        if par:IsA("BasePart") then
            pos = par.Position
        elseif par:IsA("Attachment") then
            pos = par.WorldPosition
        elseif par:IsA("Model") then
            local pp = par.PrimaryPart or par:FindFirstChildWhichIsA("BasePart")
            if pp then pos = pp.Position end
        else
            local bp = par:FindFirstChildWhichIsA("BasePart", true)
            if bp then pos = bp.Position end
        end
    end)
    return pos
end

local function buildCallbacks(prompt)
    if stealCache[prompt] then return end
    local data = { holdCBs = {}, triggerCBs = {}, ready = true }
    local ok1, c1 = pcall(getconnections, prompt.PromptButtonHoldBegan)
    if ok1 and type(c1) == "table" then
        for _, conn in ipairs(c1) do
            if type(conn.Function) == "function" then
                table.insert(data.holdCBs, conn.Function)
            end
        end
    end
    local ok2, c2 = pcall(getconnections, prompt.Triggered)
    if ok2 and type(c2) == "table" then
        for _, conn in ipairs(c2) do
            if type(conn.Function) == "function" then
                table.insert(data.triggerCBs, conn.Function)
            end
        end
    end
    if #data.holdCBs > 0 or #data.triggerCBs > 0 then
        stealCache[prompt] = data
    end
end

local function execSteal(prompt)
    local data = stealCache[prompt]
    if not data or not data.ready then return false end
    data.ready = false
    task.spawn(function()
        for _, fn in ipairs(data.holdCBs) do task.spawn(fn) end
        task.wait(0.08)
        for _, fn in ipairs(data.triggerCBs) do task.spawn(fn) end
        task.wait(0.01)
        data.ready = true
    end)
    return true
end

local function firePrompt(prompt)
    local fired = false
    pcall(function()
        if fireproximityprompt then
            prompt.HoldDuration = 0
            fireproximityprompt(prompt, 0, 0)
            fired = true
        end
    end)
    if fired then return end
    local ok, conns = pcall(getconnections, prompt.Triggered)
    if ok and type(conns) == "table" then
        for _, c in ipairs(conns) do
            if c.Function then task.spawn(c.Function) end
        end
        return
    end
    pcall(function()
        prompt:InputHoldBegin()
        task.delay(0.04, function() pcall(function() prompt:InputHoldEnd() end) end)
    end)
end

-- البحث عن أقرب برومبت (محسن)
local promptCache = {}
local lastCacheUpdate = 0
local CACHE_REFRESH = 0.1

local function refreshPromptCache()
    local now = tick()
    if now - lastCacheUpdate < CACHE_REFRESH then return promptCache end
    
    promptCache = {}
    local plots = workspace:FindFirstChild("Plots")
    if not plots then return promptCache end
    
    for _, plot in pairs(plots:GetChildren()) do
        for _, desc in pairs(plot:GetDescendants()) do
            if desc:IsA("ProximityPrompt") and desc.Enabled and not IsOwnPrompt(desc) then
                local pos = GetPromptPos(desc)
                if pos then
                    table.insert(promptCache, {
                        prompt = desc,
                        position = pos,
                        maxDist = desc.MaxActivationDistance or 10
                    })
                end
            end
        end
    end
    lastCacheUpdate = now
    return promptCache
end

local function findNearestPrompt()
    if not HRP then return nil end
    
    local cache = refreshPromptCache()
    local nearest = nil
    local bestDist = GRAB_RADIUS
    local currentPos = HRP.Position
    
    for _, item in ipairs(cache) do
        if item.prompt and item.prompt.Parent and item.prompt.Enabled then
            local d = (currentPos - item.position).Magnitude
            if d < bestDist then
                bestDist = d
                nearest = item.prompt
            end
        end
    end
    return nearest
end

-- ===== تشغيل وإيقاف السرقة =====
local function StartGrab()
    if GRAB_ACTIVE then return end
    GRAB_ACTIVE = true
    grabTimer = 0
    UpdateUI()
    
    if grabMainConn then grabMainConn:Disconnect() end
    grabMainConn = RunService.Heartbeat:Connect(function(dt)
        if not GRAB_ACTIVE then
            if grabMainConn then grabMainConn:Disconnect(); grabMainConn = nil end
            UpdateUI()
            return
        end
        if not HRP then return end
        
        local bestPrompt = findNearestPrompt()
        
        if bestPrompt then
            grabTimer = grabTimer + dt
            UpdateUI()
            if grabTimer >= GRAB_RATE then
                grabTimer = 0
                buildCallbacks(bestPrompt)
                if not execSteal(bestPrompt) then firePrompt(bestPrompt) end
                UpdateUI()
            end
        else
            if grabTimer > 0 then
                grabTimer = 0
                UpdateUI()
            end
        end
    end)
end

local function StopGrab()
    GRAB_ACTIVE = false
    if grabMainConn then grabMainConn:Disconnect(); grabMainConn = nil end
    grabTimer = 0
    UpdateUI()
end

local function ToggleGrab()
    if GRAB_ACTIVE then StopGrab() else StartGrab() end
    UpdateUI()
end

